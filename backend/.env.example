# Backend API server — copy to backend/.env.local (or repo root .env.local for local dev)

PORT=4000

# Comma-separated allowed frontend origins for CORS (production)
# CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:3000

OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini
OPENROUTER_EXTRACT_MODEL=openai/gpt-4.1-mini

# Direct provider keys (when Settings → Use OpenRouter is unchecked)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# EXTRACT_PROVIDER=openai
# EXTRACT_MODEL=gpt-4o-mini
#
# Speed tips (direct mode):
# - deepseek-chat is much faster than deepseek-v4-pro for resume + job extract
# - deepseek-v4-pro outputs planning prose, not JSON — auto-fallback uses DEEPSEEK_JSON_MODEL (default deepseek-chat)
# DEEPSEEK_JSON_MODEL=deepseek-chat
# - RESUME_PROMPT_COMPACT=true skips industry buzzword lists in the resume prompt
# - RESUME_GENERATION_MAX_TOKENS=4096 caps output size (default for DeepSeek)
# - EXTRACT_MAX_TOKENS=4096 for job page extract (includes full JD in JSON)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=  (admin user list — server only)
# ADMIN_EMAILS=you@example.com

# Weekly bid cleanup (Sundays, server local time). Requires SUPABASE_SERVICE_ROLE_KEY.
# WEEKLY_CLEANUP_ENABLED=true
# WEEKLY_CLEANUP_HOUR=3

# Optional: resume HTML templates (defaults to ../templates from backend cwd)
# TEMPLATES_DIR=../templates

# Optional: Astrill / corporate proxy
# HTTPS_PROXY=http://127.0.0.1:3213
# AI_REQUEST_TIMEOUT_MS=300000

# PDF generation — use installed Chrome if Puppeteer's bundled browser wasn't downloaded
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
