# Copy to frontend/.env.local

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production: set to your backend URL (no trailing slash)
# NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Local dev: point at backend directly (avoids Next.js rewrite proxy + DEP0060 warning)
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Or leave unset to proxy /api/* via next.config.js rewrites (may log DEP0060 on Node 22+)
