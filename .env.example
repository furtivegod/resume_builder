# Shared / monorepo — copy values into frontend/.env.local and backend/.env

# ── Frontend (frontend/.env.local) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Production: URL of deployed backend API
# NEXT_PUBLIC_API_URL=https://api.your-domain.com
# Local dev: leave NEXT_PUBLIC_API_URL empty; Next.js proxies /api/* to BACKEND_URL
# BACKEND_URL=http://localhost:4000

# ── Backend (backend/.env) ──
# PORT=4000
# CORS_ORIGIN=http://localhost:3000
# OPENROUTER_API_KEY=
# OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini
# OPENROUTER_EXTRACT_MODEL=openai/gpt-4.1-mini
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# NEXT_PUBLIC_SUPABASE_URL=  (same as frontend — used to verify JWTs)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=  (admin user management — server only, never expose to frontend)
# ADMIN_EMAILS=you@example.com,other@example.com
